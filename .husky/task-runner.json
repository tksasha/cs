{
  "tasks": [
    {
      "name": "dotnet-format-playground",
      "command": "dotnet",
      "args": [
        "format",
        "Playground",
        "--include",
        "${staged}"
      ],
      "include": [
        "**/*.cs"
      ]
    },
    {
      "name": "dotnet-format-playground-verify",
      "command": "dotnet",
      "args": [
        "format",
        "Playground.slnx",
        "--verify-no-changes",
        "--include",
        "${staged}"
      ],
      "include": [
        "**/*.cs"
      ]
    }
  ]
}