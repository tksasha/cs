{
  "tasks": [
    {
      "name": "dotnet-format-beetles",
      "command": "dotnet",
      "args": [
        "format",
        "Beetles/Beetles.slnx",
        "--include",
        "${staged}"
      ],
      "include": [
        "**/*.cs"
      ]
    },
    {
      "name": "dotnet-format-beetles-verify",
      "command": "dotnet",
      "args": [
        "format",
        "Beetles/Beetles.slnx",
        "--verify-no-changes",
        "--include",
        "${staged}"
      ]
    }
  ]
}
